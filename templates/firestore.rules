rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default: authenticated users can read/write anything under their own
    // /users/<uid>/... tree (the doc itself + any subcollection or document
    // nested below it). This is the common "per-user private workspace"
    // pattern — e.g. /users/<uid>/notes/<noteId>, /users/<uid>/settings, etc.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Everything else is closed by default. Override per-collection above
    // when you want to expose something publicly or shared across users.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
